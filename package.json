{
  "name": "clipboard",
  "version": "1.0.0",
  "main": "src/main/index.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "build:vite": "vite build",
    "build": "npm run build:vite && electron-builder"
  },
  "description": "ClipMate - A sleek, premium, cross-platform clipboard manager built with Electron, React, and Vite. Features instant keyboard shortcuts, real-time image previews, detailed history search, settings configurations, and customizable theme integrations.",
  "homepage": "https://github.com/Jewel-cse/clip-mate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jewel-cse/clip-mate.git"
  },
  "bugs": {
    "url": "https://github.com/Jewel-cse/clip-mate/issues"
  },
  "keywords": [
    "clipboard",
    "clipboard-manager",
    "electron",
    "react",
    "vite",
    "desktop-app",
    "productivity",
    "windows",
    "macos",
    "linux",
    "shortcuts",
    "utility",
    "tray-app"
  ],
  "author": "Rana",
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  }
}
